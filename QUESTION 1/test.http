# Keep the server running in a terminal after starting it with:
# node "QUESTION 1/server.js"

### Check the root route
GET http://localhost:3000/

### Add a new book
POST http://localhost:3000/books
Content-Type: application/json

{
  "id": "1",
  "title": "Java",
  "author": "ABC"
}

### Get the book list
GET http://localhost:3000/books

### Get the book by id 1
GET http://localhost:3000/books/1

### Borrow the book with id 1
POST http://localhost:3000/books/borrow/1

### Delete the book with id 1
DELETE http://localhost:3000/books/1
